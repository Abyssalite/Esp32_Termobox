<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Esp32_Control.ViewModels"
             x:Class="Esp32_Control.Views.DeviceView"
             x:DataType="vm:DeviceViewModel">

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" VerticalAlignment="Center" CornerRadius="10" Background="#3333">
            <Grid ColumnDefinitions="Auto,*">		
                <Button
                    Grid.Column="0"
                    Width="40" 
                    Height="40" 
                    Padding="10"
                    Margin="10"
                    CornerRadius="30"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    BorderBrush="Transparent"
                    Background="#FAAA"
                    Command="{Binding BackCommand}">
                    <Image Source="avares://Esp32_Control/Assets/icons8-back-100.png"
                        Stretch="Uniform"
                        Width="50"
                        Height="50" />
                </Button>   

                <StackPanel Grid.Column="1" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Margin="0 0 0 20">

                    <TextBlock  Text="{Binding SelectedDevice.Name}" 
                        FontSize="30"
                        HorizontalAlignment="Center" />
                        
                    <StackPanel Orientation="Horizontal">
                        <TextBlock  Text="{Binding SelectedDevice.Address}" 
                            FontSize="22"
                            Margin="5" />
                        <TextBlock  Text="{Binding Status}" 
                            FontSize="22"
                            Margin="5" />
                    </StackPanel>
                </StackPanel>
            </Grid>   
        </Border>

        <Grid x:Name="DeviceStatusGrid" Grid.Row="1" HorizontalAlignment="Stretch" RowDefinitions="*,Auto">
          	<ContentControl x:Name="DeviceStatusContent" Content="{Binding TabView.MainTab}" />
          	<ContentControl x:Name="DeviceSettingContent" Content="{Binding TabView.SecondaryTab}" />
        </Grid>
    </Grid>

</UserControl>
